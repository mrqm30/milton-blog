---
import Base from "../layouts/Base.astro";
import { withBase as to } from "../lib/paths";
---

<Base>
  <section class="hero-section container-p">
    <div class="flex flex-col md:flex-row items-center md:items-start gap-8">
      <img 
        src={to("avatar.png")} 
        alt="Milton Quintana Moreno" 
        class="avatar-hero"
        width="160"
        height="160"
      />
      
      <div class="flex-1 text-center md:text-left">
        <h1 class="hero-title">Milton Quintana Moreno</h1>
        <p class="hero-sub">Científico de Datos — Ingeniero Físico</p>

        <div class="hero-buttons justify-center md:justify-start">
          <a class="btn btn-primary" href={to("about")}>Sobre mí</a>
          <a class="btn btn-ghost" href={to("projects")}>Proyectos</a>
        </div>
      </div>
    </div>
  </section>

  <section class="grid sm:grid-cols-3 gap-6 mt-12 container-p">
    <div class="card">
      <h3>Últimos proyectos</h3>
      <p>Pipelines, dashboards y ML experiments.</p>
      <a class="btn btn-ghost mt-4" href={to("projects")}>Ver proyectos</a>
    </div>
    <div class="card">
      <h3>Publicaciones</h3>
      <p>Modelado numérico y notas técnicas.</p>
      <a class="btn btn-ghost mt-4" href={to("publications")}>Ver publicaciones</a>
    </div>
    <div class="card">
      <h3>Habilidades</h3>
      <p>Stack de datos, ML y web.</p>
      <a class="btn btn-ghost mt-4" href={to("skills")}>Ver habilidades</a>
    </div>
  </section>
</Base>
